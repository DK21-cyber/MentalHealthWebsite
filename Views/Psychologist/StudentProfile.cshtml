@model PW.Models.Student

@{
    ViewData["Title"] = "Student Profile";
}

<div class="container py-5">

    <div class="row">

        <!-- Left Panel -->

        <div class="col-lg-4">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <img src="~/images/default-avatar.png"
                         class="rounded-circle mb-3"
                         width="120"
                         height="120" />

                    <h3 class="fw-bold">

                        @Model.Name

                    </h3>

                    <p class="text-muted">

                        Student

                    </p>

                    <hr />

                    <table class="table table-borderless">

                        <tr>

                            <th>Student Code</th>

                            <td>

                                @Model.StudentCode

                            </td>

                        </tr>

                        <tr>

                            <th>Class</th>

                            <td>

                                @Model.Class

                            </td>

                        </tr>

                        <tr>

                            <th>Email</th>

                            <td>

                                @Model.User?.Email

                            </td>

                        </tr>

                    </table>

                </div>

            </div>

        </div>

        <!-- Right Panel -->

        <div class="col-lg-8">

            <!-- Psychological Profile -->

            <div class="card shadow-sm mb-4">

                <div class="card-header">

                    <h5 class="mb-0">

                        Latest Psychological Profile

                    </h5>

                </div>

                <div class="card-body">

                    @if (Model.PsychologicalProfiles.Any())
                    {
                        var profile = Model.PsychologicalProfiles
                        .OrderByDescending(x => x.CreatedAt)
                        .First();

                        <table class="table">

                            <tr>

                                <th width="180">

                                    Status

                                </th>

                                <td>

                                    @profile.Status

                                </td>

                            </tr>

                            <tr>

                                <th>

                                    Diagnosis

                                </th>

                                <td>

                                    @(string.IsNullOrWhiteSpace(profile.Diagnosis)
                                                                    ? "Not available"
                                                                    : profile.Diagnosis)

                                </td>

                            </tr>

                            <tr>

                                <th>

                                    Psychologist

                                </th>

                                <td>

                                    @profile.Psychologist?.Name

                                </td>

                            </tr>

                            <tr>

                                <th>

                                    Notes

                                </th>

                                <td>

                                    @(string.IsNullOrWhiteSpace(profile.Notes)
                                                                    ? "No notes"
                                                                    : profile.Notes)

                            </td>

                            </tr>

                            <tr>

                                <th>

                                    Created At

                                </th>

                                <td>

                                    @profile.CreatedAt.ToString("dd/MM/yyyy HH:mm")

                                </td>

                            </tr>

                        </table>
                                        }
                    else
                    {
                        <div class="alert alert-warning">

                            No psychological profile found.

                        </div>
                    }

                </div>

            </div>

            <!-- Assessment History -->

            <div class="card shadow-sm mb-4">

                <div class="card-header">

                    <h5 class="mb-0">

                        Assessment History

                    </h5>

                </div>

                <div class="card-body">

                    <table class="table table-hover">

                        <thead>

                            <tr>

                                <th>Date</th>

                                <th>Survey</th>

                                <th>Total Score</th>

                                <th>Risk Level</th>

                            </tr>

                        </thead>

                        <tbody>

                            @if (Model.SurveyResults.Any())
                            {
                                @foreach (var item in Model.SurveyResults
                                                            .OrderByDescending(x => x.SubmittedAt))
                                {
                                    <tr>

                                        <td>

                                            @item.SubmittedAt.ToString("dd/MM/yyyy")

                                        </td>

                                        <td>

                                            @item.Survey?.Title

                                        </td>

                                        <td>

                                            @item.TotalScore

                                        </td>

                                        <td>

                                            <span class="badge bg-info">

                                                @item.RiskLevel

                                            </span>

                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>

                                    <td colspan="4"
                                        class="text-center text-muted">

                                        No assessment history available.

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

            <!-- Latest AI Summary -->
            @if (Model.SurveyResults.Any())
            {
                var latest = Model.SurveyResults
                .OrderByDescending(x => x.SubmittedAt)
                .First();

                <div class="card shadow-sm mb-4">

                    <div class="card-header">

                        <h5 class="mb-0">

                            Latest Assessment Summary

                        </h5>

                    </div>

                    <div class="card-body">

                        @if (string.IsNullOrWhiteSpace(latest.ResultSummary))
                        {
                            <p class="text-muted">

                                No summary available.

                            </p>
                        }
                        else
                        {
                            <p>

                                @latest.ResultSummary

                            </p>
                        }

                    </div>

                </div>
            }

            <div class="text-end">

                <a asp-controller="Appointment"
                   asp-action="Book"
                   class="btn btn-primary">

                    Book Appointment

                </a>

            </div>

        </div>

    </div>

</div>