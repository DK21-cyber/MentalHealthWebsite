@model PW.Models.ViewModels.CreateAppointmentViewModel

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0 rounded-4">

                <div class="card-header bg-primary text-white p-4">

                    <h2 class="mb-2">

                        Book a Counseling Appointment

                    </h2>

                    <p class="mb-0">

                        Schedule a confidential session with one of our professional psychologists.

                    </p>

                </div>

                <div class="card-body p-4">

                    <form asp-action="Book">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <div class="mb-4">

                            <label asp-for="PsychologistId"
                                   class="form-label fw-semibold">
                            </label>

                            <select asp-for="PsychologistId"
                                    asp-items="Model.Psychologists"
                                    class="form-select">

                                <option value="">

                                    Select a psychologist

                                </option>

                            </select>

                        </div>

                        <div class="mb-4">

                            <label asp-for="ScheduleSlotId"
                                   class="form-label fw-semibold">
                            </label>

                            <select asp-for="ScheduleSlotId"
                                    asp-items="Model.ScheduleSlots"
                                    class="form-select">

                                <option value="">

                                    Select an available time

                                </option>

                            </select>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Description"
                                   class="form-label fw-semibold">

                                Reason for Appointment

                            </label>

                            <textarea asp-for="Description"
                                      rows="6"
                                      class="form-control"
                                      placeholder="Briefly describe your concerns or the reason you would like to meet with a psychologist.">
                            </textarea>

                        </div>

                        <div class="d-flex justify-content-end">

                            <a asp-action="Schedule"
                               class="btn btn-outline-secondary me-2">

                                Cancel

                            </a>

                            <button class="btn btn-primary">

                                <i class="bi bi-calendar-check me-2"></i>

                                Confirm Appointment

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
