@{
    ViewData["Title"] = "Contact";
}

<section class="page-banner">

    <div class="container">

        <h1>Contact Us</h1>

        <p>
            Send your feedback or contact us regarding this research project.
        </p>

    </div>

</section>

<!-- CONTACT SECTION -->

<section class="contact-page">

    <div class="container">

        <div class="contact-wrapper">

            <!-- LEFT -->

            <div class="contact-info">

                <h2>Contact Information</h2>

                <div class="info-item">

                    <h4>Research Author</h4>

                    <p>Le My Ky Duyen</p>

                </div>

                <div class="info-item">

                    <h4>Email</h4>

                    <p>duyenlmk21@uef.edu.vn</p>

                </div>

                <div class="info-item">

                    <h4>Major</h4>

                    <p>Information Technology</p>

                </div>

                <div class="info-item">

                    <h4>Research Area</h4>

                    <p>
                        Machine Learning Applications for
                        Student Mental Health Screening
                    </p>

                </div>

            </div>

            <!-- RIGHT -->

            <div class="contact-form-box">

                <h2>Send Feedback</h2>

                <form>

                    <div class="form-group">

                        <label>Full Name</label>

                        <input type="text"
                               placeholder="Enter your full name">

                    </div>

                    <div class="form-group">

                        <label>Email</label>

                        <input type="email"
                               placeholder="Enter your email address">

                    </div>

                    <div class="form-group">

                        <label>Subject</label>

                        <input type="text"
                               placeholder="Enter the subject">

                    </div>

                    <div class="form-group">

                        <label>Message</label>

                        <textarea rows="6"
                                  placeholder="Write your message here"></textarea>

                    </div>

                    <button type="submit"
                            class="btn-submit">

                        Send Feedback

                    </button>

                </form>

            </div>

        </div>

    </div>

</section>

<!-- FAQ -->

<section class="faq">

    <div class="container">

        <div class="section-title">

            <h2>Frequently Asked Questions</h2>

        </div>

        <div class="faq-list">

            <div class="faq-item">

                <h3>
                    Can this system replace a psychologist?
                </h3>

                <p>
                    No. The system is designed only as an
                    initial mental health screening and
                    early warning support tool. It does not
                    replace professional psychological diagnosis
                    or treatment.
                </p>

            </div>

            <div class="faq-item">

                <h3>
                    Is my survey data kept confidential?
                </h3>

                <p>
                    Yes. All personal information and survey
                    responses are stored and processed securely
                    following data privacy and confidentiality
                    principles.
                </p>

            </div>

            <div class="faq-item">

                <h3>
                    Are the assessment results completely accurate?
                </h3>

                <p>
                    The assessment results are intended for
                    reference and early screening purposes only.
                    They should always be interpreted together
                    with professional psychological evaluation.
                </p>

            </div>

        </div>

    </div>

</section>