@{
    ViewData["Title"] = "About";
}

<section class="page-banner">

    <div class="container">

        <h1>About the Research</h1>

        <p>
            Applying Machine Learning for Student Mental Health Screening
        </p>

    </div>

</section>

<!-- ABOUT PROJECT -->

<section class="about-project">

    <div class="container">

        <div class="about-grid">

            <div class="about-image">

                <img src="~/images/about-research.jpg"
                     alt="Research">

            </div>

            <div class="about-content">

                <h2>Project Overview</h2>

                <p>
                    This research focuses on developing an intelligent
                    mental health screening system for university students
                    using Machine Learning models trained on psychological
                    survey data and demographic information.
                </p>

                <p>
                    The system supports the assessment of three common
                    psychological conditions: <strong>Depression</strong>,
                    <strong>Anxiety</strong>, and <strong>Stress</strong>,
                    enabling early identification of students who may be
                    at risk and require professional support.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- OBJECTIVES -->

<section class="objectives">

    <div class="container">

        <div class="section-title">

            <h2>Research Objectives</h2>

        </div>

        <div class="objective-grid">

            <div class="objective-card">

                <h3>Data Collection</h3>

                <p>
                    Build a psychological dataset containing
                    515 student survey responses.
                </p>

            </div>

            <div class="objective-card">

                <h3>Machine Learning Training</h3>

                <p>
                    Train and compare 11 Machine Learning
                    algorithms to identify the most suitable model.
                </p>

            </div>

            <div class="objective-card">

                <h3>System Development</h3>

                <p>
                    Develop a web-based platform for psychological
                    assessment, profile management, and early warning support.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- TECHNOLOGY -->

<section class="technology">

    <div class="container">

        <div class="section-title">

            <h2>Technologies Used</h2>

        </div>

        <div class="tech-grid">

            <div class="tech-card">

                <h3>ASP.NET Core MVC</h3>

                <p>
                    Web application development framework.
                </p>

            </div>

            <div class="tech-card">

                <h3>Machine Learning</h3>

                <p>
                    Data analysis and psychological risk prediction.
                </p>

            </div>

            <div class="tech-card">

                <h3>Python</h3>

                <p>
                    Model training, evaluation, and deployment.
                </p>

            </div>

            <div class="tech-card">

                <h3>SQL Server</h3>

                <p>
                    Database management for application and survey data.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- RESULTS -->

<section class="research-result">

    <div class="container">

        <div class="section-title">

            <h2>Research Results</h2>

        </div>

        <div class="result-summary">

            <div class="summary-box">

                <h3>515</h3>

                <span>Survey Responses</span>

            </div>

            <div class="summary-box">

                <h3>11</h3>

                <span>Machine Learning Models</span>

            </div>

            <div class="summary-box">

                <h3>49%</h3>

                <span>Logistic Regression Accuracy</span>

            </div>

            <div class="summary-box">

                <h3>50%</h3>

                <span>SVM Accuracy</span>

            </div>

        </div>

    </div>

</section>

<!-- AUTHOR -->

<section class="team">

    <div class="container">

        <div class="section-title">

            <h2>Research Author</h2>

        </div>

        <div class="team-card">

            <h3>Lee Duyen</h3>

            <p>
                Information Technology Student
            </p>

            <p>
                Conducting research on Artificial Intelligence
                applications for psychological assessment,
                mental health management, and early intervention
                support for university students.
            </p>

        </div>

    </div>

</section>