@model PW.Models.ViewModels.DASSRequestViewModel

@{
    ViewData["Title"] = "DASS-21 Survey";

    string[] questions =
    {
        "Tôi cảm thấy khó thư giãn.",
        "Tôi bị khô miệng.",
        "Tôi không thể cảm nhận được bất kỳ cảm xúc tích cực nào.",
        "Tôi cảm thấy khó thở.",
        "Tôi thấy khó bắt tay vào công việc.",
        "Tôi phản ứng thái quá với các tình huống.",
        "Tôi cảm thấy run rẩy.",
        "Tôi cảm thấy tiêu hao nhiều năng lượng thần kinh.",
        "Tôi lo lắng về những tình huống có thể khiến tôi hoảng sợ.",
        "Tôi cảm thấy mình không có gì để mong đợi.",
        "Tôi thấy bản thân dễ bị kích động.",
        "Tôi cảm thấy khó thư giãn tinh thần.",
        "Tôi cảm thấy buồn và chán nản.",
        "Tôi không chịu được bất cứ điều gì cản trở công việc của mình.",
        "Tôi cảm thấy gần như hoảng loạn.",
        "Tôi không thể hứng thú với bất cứ điều gì.",
        "Tôi cảm thấy mình không có nhiều giá trị.",
        "Tôi dễ nổi nóng.",
        "Tôi nhận thấy nhịp tim tăng dù không vận động.",
        "Tôi cảm thấy sợ hãi vô cớ.",
        "Tôi cảm thấy cuộc sống không có ý nghĩa."
    };

    string[] options =
    {
        "0 - Không đúng với tôi",
        "1 - Đúng với tôi một phần",
        "2 - Đúng với tôi phần lớn thời gian",
        "3 - Đúng với tôi rất nhiều"
    };
}

<div class="container py-5">

    <div class="survey-container">

        <div class="survey-header text-center mb-5">

            <h2>Khảo sát DASS-21</h2>

            <p class="text-muted">
                Vui lòng chọn mức độ phù hợp với trải nghiệm của bạn
                trong 1 tuần gần đây.
            </p>

        </div>

        <form asp-controller="Survey"
              asp-action="TakeSurvey"
              method="post">

            @for (int i = 1; i <= 21; i++)
            {
                <div class="card shadow-sm mb-4">

                    <div class="card-body">

                        <h5 class="mb-3">
                            Câu @i
                        </h5>

                        <p>
                            @questions[i - 1]
                        </p>

                        @for (int j = 0; j < options.Length; j++)
                        {
                            <div class="form-check mb-2">

                                <input class="form-check-input"
                                       type="radio"
                                       name="Q@(i)"
                                       id="Q@(i)_@j"
                                       value="@j"
                                       required>

                                <label class="form-check-label"
                                       for="Q@(i)_@j">

                                    @options[j]

                                </label>

                            </div>
                        }

                    </div>

                </div>
            }

            <div class="text-center">

                <button type="submit"
                        class="btn btn-primary btn-lg">

                    Nộp khảo sát

                </button>

            </div>

        </form>

    </div>

</div>
