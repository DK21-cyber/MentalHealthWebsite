@model PW.Models.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-container">

    <div class="auth-left">

        <div class="auth-overlay">

            <h1>Mental Health AI</h1>

            <p>
                Reset your account password to continue using
                the Mental Health AI platform.
            </p>

        </div>

    </div>

    <div class="auth-right">

        <div class="auth-card">

            <h2>Forgot Password</h2>

            <p class="auth-subtitle">

                Enter your email and create a new password.

            </p>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">

                    @TempData["Error"]

                </div>
            }

            <form asp-action="ForgotPassword"
                  method="post">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="form-group mb-3">

                    <label asp-for="Email"></label>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Enter your email" />

                    <span asp-validation-for="Email"
                          class="text-danger"></span>

                </div>

                <div class="form-group mb-3">

                    <label asp-for="NewPassword"></label>

                    <input asp-for="NewPassword"
                           class="form-control"
                           placeholder="Enter new password" />

                    <span asp-validation-for="NewPassword"
                          class="text-danger"></span>

                </div>

                <div class="form-group mb-4">

                    <label asp-for="ConfirmPassword"></label>

                    <input asp-for="ConfirmPassword"
                           class="form-control"
                           placeholder="Confirm new password" />

                    <span asp-validation-for="ConfirmPassword"
                          class="text-danger"></span>

                </div>

                <button class="btn-auth w-100">

                    Reset Password

                </button>

            </form>

            <div class="auth-footer mt-4">

                Remember your password?

                <a asp-action="Login">

                    Back to Login

                </a>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}