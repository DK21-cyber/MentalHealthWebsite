@model IEnumerable<PW.Models.ViewModels.SurveyHistoryViewModel>

@{
    ViewData["Title"] = "Survey History";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>
            Survey History
        </h2>

        <a asp-action="TakeSurvey"
           class="btn btn-primary">

            Take New Survey

        </a>

    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">

            No survey records found.

        </div>
    }
    else
    {
        <div class="card shadow">

            <div class="card-body">

                <table class="table table-hover">

                    <thead>

                        <tr>

                            <th>Survey</th>

                            <th>Date</th>

                            <th>Total Score</th>

                            <th>Risk Level</th>

                            <th></th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>

                                    @item.SurveyName

                                </td>

                                <td>

                                    @item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")

                                </td>

                                <td>

                                    @item.TotalScore

                                </td>

                                <td>

                                    @if (item.RiskLevel == "Very Severe")
                                    {
                                        <span class="badge bg-danger">
                                            @item.RiskLevel
                                        </span>
                                    }
                                    else if (item.RiskLevel == "Severe")
                                    {
                                        <span class="badge bg-warning">
                                            @item.RiskLevel
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            @item.RiskLevel
                                        </span>
                                    }

                                </td>

                                <td>

                                    <a asp-action="SurveyDetail"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-primary">

                                        View

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    }

</div>