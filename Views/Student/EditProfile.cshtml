@model PW.Models.ViewModels.EditStudentProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow">

                <div class="card-header">

                    <h3 class="mb-0">
                        Edit Profile
                    </h3>

                </div>

                <div class="card-body">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">

                            @TempData["Success"]

                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">

                            @TempData["Error"]

                        </div>
                    }

                    <form asp-action="EditProfile"
                          method="post">

                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <input asp-for="Id" type="hidden" />
                        <input asp-for="UserId" type="hidden" />

                        <div class="mb-3">

                            <label asp-for="Name"
                                   class="form-label">
                            </label>

                            <input asp-for="Name"
                                   class="form-control" />

                            <span asp-validation-for="Name"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Email"
                                   class="form-label">
                            </label>

                            <input asp-for="Email"
                                   class="form-control"
                                   readonly />

                            <small class="text-muted">
                                Email cannot be changed.
                            </small>

                        </div>

                        <div class="mb-3">

                            <label asp-for="StudentCode"
                                   class="form-label">
                            </label>

                            <input asp-for="StudentCode"
                                   class="form-control" />

                            <span asp-validation-for="StudentCode"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="mb-3">

                            <label asp-for="Class"
                                   class="form-label">
                            </label>

                            <input asp-for="Class"
                                   class="form-control" />

                            <span asp-validation-for="Class"
                                  class="text-danger">
                            </span>

                        </div>

                        <hr />

                        <div class="d-flex justify-content-end">

                            <a asp-action="Profile"
                               class="btn btn-secondary me-2">

                                Cancel

                            </a>

                            <button type="submit"
                                    class="btn btn-primary">

                                Save Changes

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}