@model PW.Models.ViewModels.StudentProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow">

                <div class="card-header">

                    <h3>

                        Student Profile

                    </h3>

                </div>

                <div class="card-body">

                    <table class="table table-bordered">

                        <tr>

                            <th width="220">

                                Full Name

                            </th>

                            <td>

                                @Model.Name

                            </td>

                        </tr>

                        <tr>

                            <th>

                                Email

                            </th>

                            <td>

                                @Model.Email

                            </td>

                        </tr>

                        <tr>

                            <th>

                                Student Code

                            </th>

                            <td>

                                @Model.StudentCode

                            </td>

                        </tr>

                        <tr>

                            <th>

                                Class

                            </th>

                            <td>

                                @Model.Class

                            </td>

                        </tr>

                        <tr>

                            <th>

                                Role

                            </th>

                            <td>

                                @Model.Role

                            </td>

                        </tr>

                        <tr>

                            <th>

                                Status

                            </th>

                            <td>

                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">

                                        Active

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">

                                        Inactive

                                    </span>
                                }

                            </td>

                        </tr>

                        <tr>

                            <th>

                                Account Created

                            </th>

                            <td>

                                @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")

                            </td>

                        </tr>

                    </table>

                </div>

                <div class="card-footer text-end">

                    <a asp-action="EditProfile"
                       class="btn btn-primary">

                        Edit Profile

                    </a>

                    <a asp-action="Index"
                       class="btn btn-secondary">

                        Back

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>