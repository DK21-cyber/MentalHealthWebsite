@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Survey Management";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <!-- HEADER -->

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-ui-checks-grid"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        Mental Health System
                    </p>

                    <h1 class="h3 mb-1">
                        Survey Management
                    </h1>

                    <p class="text-muted mb-0">
                        Manage psychological screening surveys.
                    </p>

                </div>

            </div>

            <div class="heading-actions">

                <a asp-action="Create"
                   class="btn btn-primary btn-sm">

                    <i class="bi bi-plus-circle"></i>
                    Create Survey

                </a>

            </div>

        </div>

        <!-- SUMMARY -->

        <section class="row g-3 mt-1">

            <div class="col-12 col-sm-6 col-xl-3">

                <article class="metric-card metric-primary">

                    <div class="metric-top">

                        <span class="metric-label">
                            Total Surveys
                        </span>

                        <span class="metric-icon">

                            <i class="bi bi-ui-checks-grid"></i>

                        </span>

                    </div>

                    <div class="metric-value">
                        5
                    </div>

                    <div class="metric-meta">

                        <span>
                            Available surveys
                        </span>

                    </div>

                </article>

            </div>

            <div class="col-12 col-sm-6 col-xl-3">

                <article class="metric-card metric-success">

                    <div class="metric-top">

                        <span class="metric-label">
                            Active Surveys
                        </span>

                        <span class="metric-icon">

                            <i class="bi bi-check-circle"></i>

                        </span>

                    </div>

                    <div class="metric-value">
                        4
                    </div>

                    <div class="metric-meta">

                        <span class="text-success">
                            Running
                        </span>

                    </div>

                </article>

            </div>

            <div class="col-12 col-sm-6 col-xl-3">

                <article class="metric-card metric-warning">

                    <div class="metric-top">

                        <span class="metric-label">
                            Questions
                        </span>

                        <span class="metric-icon">

                            <i class="bi bi-question-circle"></i>

                        </span>

                    </div>

                    <div class="metric-value">
                        63
                    </div>

                    <div class="metric-meta">

                        <span>
                            Total questions
                        </span>

                    </div>

                </article>

            </div>

            <div class="col-12 col-sm-6 col-xl-3">

                <article class="metric-card metric-danger">

                    <div class="metric-top">

                        <span class="metric-label">
                            Responses
                        </span>

                        <span class="metric-icon">

                            <i class="bi bi-bar-chart"></i>

                        </span>

                    </div>

                    <div class="metric-value">
                        515
                    </div>

                    <div class="metric-meta">

                        <span>
                            Survey submissions
                        </span>

                    </div>

                </article>

            </div>

        </section>

        <!-- TABLE -->

        <section class="panel mt-3">

            <div class="panel-header">

                <div>

                    <h2 class="h5 mb-1 section-title">

                        <i class="bi bi-table"></i>

                        <span>
                            Survey List
                        </span>

                    </h2>

                    <p class="text-muted mb-0">

                        Manage available mental health surveys.

                    </p>

                </div>

                <div class="d-flex flex-wrap gap-2">

                    <input class="form-control form-control-sm table-search"
                           type="search"
                           placeholder="Search survey">

                </div>

            </div>

            <div class="table-responsive">

                <table class="table align-middle mb-0">

                    <thead>

                        <tr>

                            <th>Survey</th>
                            <th>Category</th>
                            <th>Questions</th>
                            <th>Responses</th>
                            <th>Status</th>
                            <th class="text-end">Action</th>

                        </tr>

                    </thead>

                    <tbody>

                        <tr>

                            <td>

                                <strong>DASS-21</strong>

                            </td>

                            <td>

                                Mental Health

                            </td>

                            <td>

                                21

                            </td>

                            <td>

                                515

                            </td>

                            <td>

                                <span class="badge text-bg-success">

                                    Active

                                </span>

                            </td>

                            <td class="text-end">

                                <a asp-action="Details"
                                   class="btn btn-light btn-sm">

                                    View

                                </a>

                            </td>

                        </tr>

                        <tr>

                            <td>

                                <strong>Stress Screening</strong>

                            </td>

                            <td>

                                Stress

                            </td>

                            <td>

                                15

                            </td>

                            <td>

                                320

                            </td>

                            <td>

                                <span class="badge text-bg-success">

                                    Active

                                </span>

                            </td>

                            <td class="text-end">

                                <a asp-action="Details"
                                   class="btn btn-light btn-sm">

                                    View

                                </a>

                            </td>

                        </tr>

                        <tr>

                            <td>

                                <strong>Anxiety Assessment</strong>

                            </td>

                            <td>

                                Anxiety

                            </td>

                            <td>

                                12

                            </td>

                            <td>

                                280

                            </td>

                            <td>

                                <span class="badge text-bg-success">

                                    Active

                                </span>

                            </td>

                            <td class="text-end">

                                <a asp-action="Details"
                                   class="btn btn-light btn-sm">

                                    View

                                </a>

                            </td>

                        </tr>

                        <tr>

                            <td>

                                <strong>Depression Screening</strong>

                            </td>

                            <td>

                                Depression

                            </td>

                            <td>

                                15

                            </td>

                            <td>

                                210

                            </td>

                            <td>

                                <span class="badge text-bg-secondary">

                                    Draft

                                </span>

                            </td>

                            <td class="text-end">

                                <a asp-action="Details"
                                   class="btn btn-light btn-sm">

                                    View

                                </a>

                            </td>

                        </tr>

                    </tbody>

                </table>

            </div>

        </section>

    </div>

</main>