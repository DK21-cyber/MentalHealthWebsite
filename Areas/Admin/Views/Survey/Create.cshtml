@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Create Survey";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <!-- PAGE HEADER -->

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-plus-circle"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        Mental Health System
                    </p>

                    <h1 class="h3 mb-1">
                        Create Survey
                    </h1>

                    <p class="text-muted mb-0">
                        Create a new psychological screening survey.
                    </p>

                </div>

            </div>

            <div class="heading-actions">

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">

                    <i class="bi bi-arrow-left"></i>
                    Back

                </a>

            </div>

        </div>

        <section class="row g-3">

            <!-- FORM -->

            <div class="col-12 col-xl-8">

                <form method="post"
                      class="panel needs-validation"
                      novalidate>

                    <div class="panel-header">

                        <div>

                            <h2 class="h5 mb-1 section-title">

                                <i class="bi bi-ui-checks-grid"></i>

                                <span>
                                    Survey Information
                                </span>

                            </h2>

                            <p class="text-muted mb-0">

                                Enter survey details.

                            </p>

                        </div>

                    </div>

                    <div class="row g-3">

                        <!-- Survey Name -->

                        <div class="col-md-12">

                            <label class="form-label">
                                Survey Name
                            </label>

                            <input type="text"
                                   class="form-control"
                                   placeholder="DASS-21 Survey"
                                   required>

                            <div class="invalid-feedback">
                                Survey name is required.
                            </div>

                        </div>

                        <!-- Category -->

                        <div class="col-md-6">

                            <label class="form-label">
                                Category
                            </label>

                            <select class="form-select" required>

                                <option value="">
                                    Select Category
                                </option>

                                <option>
                                    Mental Health
                                </option>

                                <option>
                                    Stress
                                </option>

                                <option>
                                    Anxiety
                                </option>

                                <option>
                                    Depression
                                </option>

                            </select>

                            <div class="invalid-feedback">
                                Please select category.
                            </div>

                        </div>

                        <!-- Question Count -->

                        <div class="col-md-6">

                            <label class="form-label">
                                Number of Questions
                            </label>

                            <input type="number"
                                   class="form-control"
                                   min="1"
                                   value="21"
                                   required>

                            <div class="invalid-feedback">
                                Enter valid number.
                            </div>

                        </div>

                        <!-- Status -->

                        <div class="col-md-6">

                            <label class="form-label">
                                Status
                            </label>

                            <select class="form-select">

                                <option>
                                    Active
                                </option>

                                <option>
                                    Draft
                                </option>

                                <option>
                                    Inactive
                                </option>

                            </select>

                        </div>

                        <!-- Estimated Duration -->

                        <div class="col-md-6">

                            <label class="form-label">
                                Duration (Minutes)
                            </label>

                            <input type="number"
                                   class="form-control"
                                   value="10">

                        </div>

                        <!-- Description -->

                        <div class="col-12">

                            <label class="form-label">
                                Description
                            </label>

                            <textarea class="form-control"
                                      rows="5"
                                      placeholder="Describe survey purpose..."
                                      required></textarea>

                            <div class="invalid-feedback">
                                Description is required.
                            </div>

                        </div>

                    </div>

                    <!-- BUTTONS -->

                    <div class="d-flex justify-content-end gap-2 mt-4">

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-primary">

                            <i class="bi bi-check-circle"></i>

                            Create Survey

                        </button>

                    </div>

                </form>

            </div>

            <!-- SIDE PANEL -->

            <div class="col-12 col-xl-4">

                <div class="panel h-100">

                    <h2 class="h5 mb-3 section-title">

                        <i class="bi bi-lightbulb"></i>

                        <span>
                            Survey Guidelines
                        </span>

                    </h2>

                    <div class="mini-card mb-3">

                        <span>Recommended Questions</span>

                        <strong>21 - 30 Questions</strong>

                    </div>

                    <div class="mini-card mb-3">

                        <span>Recommended Duration</span>

                        <strong>5 - 15 Minutes</strong>

                    </div>

                    <div class="mini-card">

                        <span>Target Group</span>

                        <strong>University Students</strong>

                    </div>

                </div>

            </div>

        </section>

    </div>

</main>