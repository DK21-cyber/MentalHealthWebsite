@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Delete Survey";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-trash"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        Survey Management
                    </p>

                    <h1 class="h3 mb-1">
                        Delete Survey
                    </h1>

                    <p class="text-muted mb-0">
                        Confirm before deleting survey.
                    </p>

                </div>

            </div>

        </div>

        <section class="row justify-content-center">

            <div class="col-xl-7">

                <div class="panel text-center">

                    <div class="mb-4">

                        <i class="bi bi-exclamation-triangle-fill
                                  text-danger"
                           style="font-size:70px;"></i>

                    </div>

                    <h3 class="mb-3">

                        Delete This Survey?

                    </h3>

                    <p class="text-muted mb-4">

                        This action cannot be undone.
                        All survey information and responses
                        related to this survey may be affected.

                    </p>

                    <div class="info-list text-start mb-4">

                        <div>

                            <span>Survey Name</span>

                            <strong>
                                DASS-21 Mental Health Survey
                            </strong>

                        </div>

                        <div>

                            <span>Survey Code</span>

                            <strong>
                                DASS21
                            </strong>

                        </div>

                        <div>

                            <span>Total Questions</span>

                            <strong>
                                21
                            </strong>

                        </div>

                        <div>

                            <span>Responses</span>

                            <strong>
                                515
                            </strong>

                        </div>

                    </div>

                    <form method="post">

                        <div class="d-flex justify-content-center gap-2">

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Cancel

                            </a>

                            <button type="submit"
                                    class="btn btn-danger">

                                <i class="bi bi-trash"></i>
                                Delete Survey

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </section>

    </div>

</main>