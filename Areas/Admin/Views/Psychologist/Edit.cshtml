@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Edit Psychologist";
}

<main class="dashboard-content">

    ```
    <div class="container-fluid px-3 px-lg-4 py-4">

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-pencil-square"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">Management</p>

                    <h1 class="h3 mb-1">
                        Edit Psychologist
                    </h1>

                    <p class="text-muted mb-0">
                        Cập nhật thông tin chuyên viên tâm lý.
                    </p>

                </div>

            </div>

            <div class="heading-actions">

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">

                    <i class="bi bi-arrow-left"></i>
                    Back

                </a>

            </div>

        </div>

        <section class="row g-3">

            <div class="col-12 col-xl-8">

                <form class="panel">

                    <div class="panel-header">

                        <div>

                            <h2 class="h5 mb-1 section-title">

                                <i class="bi bi-person-vcard"></i>

                                <span>Psychologist Information</span>

                            </h2>

                        </div>

                    </div>

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Full Name</label>
                            <input type="text"
                                   class="form-control"
                                   value="ThS. Nguyễn Minh Anh">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email"
                                   class="form-control"
                                   value="anh.nguyen@uef.edu.vn">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Phone</label>
                            <input type="text"
                                   class="form-control"
                                   value="0901234567">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Qualification</label>
                            <input type="text"
                                   class="form-control"
                                   value="Thạc sĩ Tâm lý học">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Experience</label>
                            <input type="number"
                                   class="form-control"
                                   value="8">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Status</label>

                            <select class="form-select">

                                <option selected>
                                    Active
                                </option>

                                <option>
                                    Inactive
                                </option>

                            </select>

                        </div>

                        <div class="col-12">

                            <label class="form-label">
                                Office
                            </label>

                            <input type="text"
                                   class="form-control"
                                   value="Building A - Room 203">

                        </div>

                        <div class="col-12">

                            <label class="form-label">
                                Specialization
                            </label>

                            <textarea class="form-control"
                                      rows="4">Tư vấn học đường, hỗ trợ tâm lý sinh viên, đánh giá DASS-21.</textarea>

                        </div>

                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-primary">

                            <i class="bi bi-save"></i>
                            Update

                        </button>

                    </div>

                </form>

            </div>

            <div class="col-xl-4">

                <div class="panel">

                    <h2 class="h5 mb-3 section-title">

                        <i class="bi bi-info-circle"></i>

                        <span>Information</span>

                    </h2>

                    <div class="alert alert-info">

                        Chỉnh sửa thông tin chuyên viên trước khi lưu.

                    </div>

                </div>

            </div>

        </section>

    </div>
    ```

</main>
