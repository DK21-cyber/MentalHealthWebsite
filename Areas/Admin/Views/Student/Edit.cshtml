@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Edit Student";
}

<div class="container-fluid px-3 px-lg-4 py-4">

    <div class="page-heading">

        <div class="page-heading-copy">

            <span class="page-icon">
                <i class="bi bi-pencil-square"></i>
            </span>

            <div>

                <p class="eyebrow mb-1">
                    Student Management
                </p>

                <h1 class="h3 mb-1">
                    Edit Student
                </h1>

                <p class="text-muted mb-0">
                    Update student profile information.
                </p>

            </div>

        </div>

    </div>

    <section class="row g-3">

        <div class="col-12 col-xl-8">

            <form class="panel">

                <div class="panel-header">

                    <div>

                        <h2 class="h5 mb-1 section-title">

                            <i class="bi bi-person-vcard"></i>

                            <span>Student Information</span>

                        </h2>

                    </div>

                </div>

                <div class="row g-3">

                    <div class="col-md-6">

                        <label class="form-label">
                            Student ID
                        </label>

                        <input class="form-control"
                               value="202300001">

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Full Name
                        </label>

                        <input class="form-control"
                               value="Nguyễn Văn A">

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Email
                        </label>

                        <input class="form-control"
                               value="student@uef.edu.vn">

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Phone Number
                        </label>

                        <input class="form-control"
                               value="0901234567">

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Date of Birth
                        </label>

                        <input type="date"
                               class="form-control"
                               value="2003-01-01">

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Gender
                        </label>

                        <select class="form-select">

                            <option>Male</option>

                            <option>Female</option>

                        </select>

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Faculty
                        </label>

                        <input class="form-control"
                               value="Information Technology">

                    </div>

                    <div class="col-md-6">

                        <label class="form-label">
                            Major
                        </label>

                        <input class="form-control"
                               value="Software Engineering">

                    </div>

                    <div class="col-12">

                        <label class="form-label">
                            Address
                        </label>

                        <textarea class="form-control"
                                  rows="3">
123 Nguyen Hue, Ho Chi Minh City
</textarea>

                    </div>

                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">

                    <a asp-action="Index"
                       class="btn btn-light">

                        Cancel

                    </a>

                    <button class="btn btn-primary">

                        <i class="bi bi-save"></i>

                        Update Student

                    </button>

                </div>

            </form>

        </div>

        <div class="col-12 col-xl-4">

            <div class="panel">

                <h2 class="h5 mb-3 section-title">

                    <i class="bi bi-info-circle"></i>

                    <span>Student Status</span>

                </h2>

                <div class="mini-card mb-3">

                    <span>Latest Survey</span>

                    <strong>15/06/2026</strong>

                </div>

                <div class="mini-card mb-3">

                    <span>Stress</span>

                    <strong class="text-danger">
                        Very Severe
                    </strong>

                </div>

                <div class="mini-card">

                    <span>Risk Level</span>

                    <strong class="text-danger">
                        High Risk
                    </strong>

                </div>

            </div>

        </div>

    </section>

</div>