@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Student Management";
}

<div class="container-fluid px-3 px-lg-4 py-4">

    <!-- Page Heading -->

    <div class="page-heading">

        <div class="page-heading-copy">

            <span class="page-icon">
                <i class="bi bi-mortarboard-fill"></i>
            </span>

            <div>

                <p class="eyebrow mb-1">
                    Mental Health AI System
                </p>

                <h1 class="h3 mb-1">
                    Student Management
                </h1>

                <p class="text-muted mb-0">
                    Manage student profiles, survey history, and psychological screening records.
                </p>

            </div>

        </div>

        <div class="heading-actions">

            <a class="btn btn-outline-secondary btn-sm"
               href="#">

                <i class="bi bi-download"></i>
                Export

            </a>

            <a class="btn btn-primary btn-sm"
               href="#">

                <i class="bi bi-person-plus"></i>
                Add Student

            </a>

        </div>

    </div>

    <!-- Summary -->

    <section class="row g-3 mt-1">

        <div class="col-12 col-sm-6 col-xl-3">

            <article class="metric-card metric-primary">

                <div class="metric-top">

                    <span class="metric-label">
                        Total Students
                    </span>

                    <span class="metric-icon">
                        <i class="bi bi-people-fill"></i>
                    </span>

                </div>

                <div class="metric-value">
                    515
                </div>

                <div class="metric-meta">

                    <span class="text-success">
                        Survey Dataset
                    </span>

                </div>

            </article>

        </div>

        <div class="col-12 col-sm-6 col-xl-3">

            <article class="metric-card metric-danger">

                <div class="metric-top">

                    <span class="metric-label">
                        High Stress
                    </span>

                    <span class="metric-icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </span>

                </div>

                <div class="metric-value">
                    390
                </div>

                <div class="metric-meta">

                    <span class="text-danger">
                        Very Severe
                    </span>

                </div>

            </article>

        </div>

        <div class="col-12 col-sm-6 col-xl-3">

            <article class="metric-card metric-warning">

                <div class="metric-top">

                    <span class="metric-label">
                        High Anxiety
                    </span>

                    <span class="metric-icon">
                        <i class="bi bi-heart-pulse-fill"></i>
                    </span>

                </div>

                <div class="metric-value">
                    439
                </div>

                <div class="metric-meta">

                    <span class="text-warning">
                        Very Severe
                    </span>

                </div>

            </article>

        </div>

        <div class="col-12 col-sm-6 col-xl-3">

            <article class="metric-card metric-success">

                <div class="metric-top">

                    <span class="metric-label">
                        High Depression
                    </span>

                    <span class="metric-icon">
                        <i class="bi bi-emoji-frown-fill"></i>
                    </span>

                </div>

                <div class="metric-value">
                    307
                </div>

                <div class="metric-meta">

                    <span class="text-success">
                        Very Severe
                    </span>

                </div>

            </article>

        </div>

    </section>

    <!-- Student List -->

    <section class="panel mt-3">

        <div class="panel-header">

            <div>

                <h2 class="h5 mb-1 section-title">

                    <i class="bi bi-table"></i>

                    <span>
                        Student List
                    </span>

                </h2>

                <p class="text-muted mb-0">

                    Student profiles and latest psychological screening results.

                </p>

            </div>

            <div class="d-flex flex-wrap gap-2">

                <input class="form-control form-control-sm table-search"
                       type="search"
                       placeholder="Search student">

                <a class="btn btn-primary btn-sm"
                   href="#">

                    <i class="bi bi-person-plus"></i>

                    Add Student

                </a>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table align-middle mb-0">

                <thead>

                    <tr>

                        <th>Student</th>

                        <th>Faculty</th>

                        <th>Stress</th>

                        <th>Anxiety</th>

                        <th>Depression</th>

                        <th>Last Survey</th>

                        <th class="text-end">
                            Action
                        </th>

                    </tr>

                </thead>

                <tbody>

                    <tr>

                        <td>

                            <div>

                                <p class="fw-semibold mb-0">
                                    Nguyen Van A
                                </p>

                                <p class="text-muted small mb-0">
                                    202300001
                                </p>

                            </div>

                        </td>

                        <td>
                            Information Technology
                        </td>

                        <td>
                            <span class="badge text-bg-danger">
                                Very Severe
                            </span>
                        </td>

                        <td>
                            <span class="badge text-bg-warning">
                                Severe
                            </span>
                        </td>

                        <td>
                            <span class="badge text-bg-primary">
                                Moderate
                            </span>
                        </td>

                        <td>
                            15/06/2026
                        </td>

                        <td class="text-end">

                            <a class="btn btn-light btn-sm">

                                View

                            </a>

                        </td>

                    </tr>

                    <tr>

                        <td>

                            <div>

                                <p class="fw-semibold mb-0">
                                    Tran Thi B
                                </p>

                                <p class="text-muted small mb-0">
                                    202300002
                                </p>

                            </div>

                        </td>

                        <td>
                            Business Administration
                        </td>

                        <td>
                            <span class="badge text-bg-success">
                                Moderate
                            </span>
                        </td>

                        <td>
                            <span class="badge text-bg-warning">
                                Severe
                            </span>
                        </td>

                        <td>
                            <span class="badge text-bg-danger">
                                Very Severe
                            </span>
                        </td>

                        <td>
                            10/06/2026
                        </td>

                        <td class="text-end">

                            <a class="btn btn-light btn-sm">

                                View

                            </a>

                        </td>

                    </tr>

                </tbody>

            </table>

        </div>

    </section>

</div>