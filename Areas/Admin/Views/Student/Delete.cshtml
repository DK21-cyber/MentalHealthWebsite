@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Delete Student";
}

<div class="container-fluid px-3 px-lg-4 py-4">

    <div class="page-heading">

        <div class="page-heading-copy">

            <span class="page-icon">

                <i class="bi bi-trash-fill"></i>

            </span>

            <div>

                <p class="eyebrow mb-1">
                    Student Management
                </p>

                <h1 class="h3 mb-1">
                    Delete Student
                </h1>

                <p class="text-muted mb-0">
                    Confirm before permanently deleting this profile.
                </p>

            </div>

        </div>

    </div>

    <section class="row justify-content-center">

        <div class="col-lg-8">

            <div class="panel">

                <div class="text-center">

                    <i class="bi bi-exclamation-triangle-fill
                              text-danger"
                       style="font-size:70px;"></i>

                    <h3 class="mt-3">

                        Are you sure?

                    </h3>

                    <p class="text-muted">

                        This action cannot be undone.

                    </p>

                </div>

                <hr>

                <div class="row g-3">

                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>Student ID</span>

                            <strong>202300001</strong>

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>Full Name</span>

                            <strong>Nguyễn Văn A</strong>

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>Email</span>

                            <strong>
                                student@uef.edu.vn
                            </strong>

                        </div>

                    </div>

                    <div class="col-md-6">

                        <div class="mini-card">

                            <span>Faculty</span>

                            <strong>
                                Information Technology
                            </strong>

                        </div>

                    </div>

                </div>

                <form method="post"
                      class="mt-4">

                    <div class="d-flex justify-content-center gap-3">

                        <a asp-action="Index"
                           class="btn btn-light">

                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-danger">

                            <i class="bi bi-trash"></i>

                            Delete Student

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </section>

</div>