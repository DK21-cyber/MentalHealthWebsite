@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Delete Appointment";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-trash"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        Appointment Management
                    </p>

                    <h1 class="h3 mb-1">
                        Delete Appointment
                    </h1>

                    <p class="text-muted mb-0">
                        Confirm appointment deletion.
                    </p>

                </div>

            </div>

        </div>

        <section class="row justify-content-center">

            <div class="col-xl-8">

                <div class="panel">

                    <div class="text-center">

                        <i class="bi bi-exclamation-triangle-fill
                                  text-danger"
                           style="font-size:70px"></i>

                        <h3 class="mt-3">

                            Delete Appointment?

                        </h3>

                        <p class="text-muted">

                            This appointment schedule will be
                            permanently removed from the system.

                        </p>

                    </div>

                    <hr>

                    <div class="row g-3">

                        <div class="col-md-6">

                            <div class="mini-card">

                                <span>Appointment Date</span>

                                <strong>15/06/2026</strong>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="mini-card">

                                <span>Time</span>

                                <strong>08:00 - 09:00</strong>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="mini-card">

                                <span>Psychologist</span>

                                <strong>
                                    Dr. Nguyễn Thị Lan
                                </strong>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="mini-card">

                                <span>Student</span>

                                <strong>
                                    Nguyễn Văn A
                                </strong>

                            </div>

                        </div>

                    </div>

                    <form method="post" class="mt-4">

                        <div class="d-flex justify-content-center gap-3">

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Cancel

                            </a>

                            <button type="submit"
                                    class="btn btn-danger">

                                <i class="bi bi-trash"></i>
                                Delete Appointment

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </section>

    </div>

</main>