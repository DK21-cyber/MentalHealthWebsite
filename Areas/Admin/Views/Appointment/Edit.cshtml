@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Edit Appointment";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-pencil-square"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        Appointment Management
                    </p>

                    <h1 class="h3 mb-1">
                        Edit Appointment
                    </h1>

                    <p class="text-muted mb-0">
                        Update consultation schedule information.
                    </p>

                </div>

            </div>

            <div class="heading-actions">

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">

                    <i class="bi bi-arrow-left"></i>
                    Back

                </a>

            </div>

        </div>

        <section class="row g-3">

            <div class="col-12 col-xl-8">

                <form method="post" class="panel">

                    <div class="panel-header">

                        <div>

                            <h2 class="h5 mb-1 section-title">

                                <i class="bi bi-calendar-event"></i>

                                <span>
                                    Appointment Information
                                </span>

                            </h2>

                        </div>

                    </div>

                    <div class="row g-3">

                        <div class="col-md-6">

                            <label class="form-label">
                                Appointment Date
                            </label>

                            <input type="date"
                                   class="form-control"
                                   value="2026-06-15">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Appointment Time
                            </label>

                            <input type="time"
                                   class="form-control"
                                   value="08:00">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Psychologist
                            </label>

                            <select class="form-select">

                                <option>
                                    Dr. Nguyễn Thị Lan
                                </option>

                                <option>
                                    Dr. Trần Minh Anh
                                </option>

                            </select>

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Student
                            </label>

                            <select class="form-select">

                                <option>
                                    Nguyễn Văn A
                                </option>

                                <option>
                                    Trần Thị B
                                </option>

                            </select>

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Location
                            </label>

                            <input type="text"
                                   class="form-control"
                                   value="Room A301">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Status
                            </label>

                            <select class="form-select">

                                <option selected>
                                    Booked
                                </option>

                                <option>
                                    Available
                                </option>

                                <option>
                                    Completed
                                </option>

                                <option>
                                    Cancelled
                                </option>

                            </select>

                        </div>

                        <div class="col-12">

                            <label class="form-label">
                                Notes
                            </label>

                            <textarea class="form-control"
                                      rows="4">Student reported academic stress.</textarea>

                        </div>

                    </div>

                    <div class="d-flex justify-content-end mt-4">

                        <button type="submit"
                                class="btn btn-primary">

                            <i class="bi bi-check-circle"></i>
                            Save Changes

                        </button>

                    </div>

                </form>

            </div>

            <div class="col-12 col-xl-4">

                <div class="panel">

                    <h2 class="h5 mb-3 section-title">

                        <i class="bi bi-info-circle"></i>

                        <span>
                            Appointment Summary
                        </span>

                    </h2>

                    <div class="mini-card mb-3">

                        <span>Schedule ID</span>

                        <strong>#APT001</strong>

                    </div>

                    <div class="mini-card mb-3">

                        <span>Duration</span>

                        <strong>60 Minutes</strong>

                    </div>

                    <div class="mini-card">

                        <span>Current Status</span>

                        <strong>Booked</strong>

                    </div>

                </div>

            </div>

        </section>

    </div>

</main>