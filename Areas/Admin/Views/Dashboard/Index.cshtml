@model PW.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>
            Dashboard
        </h2>

        <span class="text-muted">
            @DateTime.Now.ToString("dddd, dd MMMM yyyy")
        </span>

    </div>

    <!-- Statistics -->

    <div class="row g-4 mb-5">

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <h2 class="fw-bold text-primary">

                        @Model.TotalStudents

                    </h2>

                    <p class="text-muted mb-0">

                        Students

                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <h2 class="fw-bold text-success">

                        @Model.TotalPsychologists

                    </h2>

                    <p class="text-muted mb-0">

                        Psychologists

                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <h2 class="fw-bold text-warning">

                        @Model.TotalAppointments

                    </h2>

                    <p class="text-muted mb-0">

                        Appointments

                    </p>

                </div>

            </div>

        </div>

        <div class="col-lg-3 col-md-6">

            <div class="card shadow-sm border-0">

                <div class="card-body text-center">

                    <h2 class="fw-bold text-danger">

                        @Model.HighRiskStudents

                    </h2>

                    <p class="text-muted mb-0">

                        High Risk Students

                    </p>

                </div>

            </div>

        </div>

    </div>

    <!-- Recent Appointments -->

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-white">

            <h5 class="mb-0">

                Recent Appointments

            </h5>

        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>

                    <tr>

                        <th>Student</th>

                        <th>Psychologist</th>

                        <th>Date</th>

                        <th>Status</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.RecentAppointments.Any())
                    {
                        foreach (var item in Model.RecentAppointments)
                        {
                            <tr>

                                <td>@item.Student?.Name</td>

                                <td>@item.Psychologist?.Name</td>

                                <td>@item.AppointmentDate.ToString("dd/MM/yyyy")</td>

                                <td>

                                    @switch (item.Status)
                                    {
                                        case PW.Models.AppointmentStatus.Pending:
                                            <span class="badge bg-warning">
                                                Pending
                                            </span>
                                            break;

                                        case PW.Models.AppointmentStatus.Approved:
                                            <span class="badge bg-primary">
                                                Approved
                                            </span>
                                            break;

                                        case PW.Models.AppointmentStatus.Completed:
                                            <span class="badge bg-success">
                                                Completed
                                            </span>
                                            break;

                                        default:
                                            <span class="badge bg-danger">
                                                Cancelled
                                            </span>
                                            break;
                                    }

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="4"
                                class="text-center text-muted">

                                No appointments found.

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- Recent Survey Results -->

    <div class="card shadow-sm">

        <div class="card-header bg-white">

            <h5 class="mb-0">

                Recent Survey Results

            </h5>

        </div>

        <div class="card-body">

            <table class="table table-hover align-middle">

                <thead>

                    <tr>

                        <th>Student</th>

                        <th>Total Score</th>

                        <th>Risk Level</th>

                        <th>Submitted</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model.RecentSurveyResults.Any())
                    {
                        foreach (var item in Model.RecentSurveyResults)
                        {
                            <tr>

                                <td>@item.Student?.Name</td>

                                <td>@item.TotalScore</td>

                                <td>

                                    <span class="badge bg-danger">

                                        @item.RiskLevel

                                    </span>

                                </td>

                                <td>

                                    @item.SubmittedAt.ToString("dd/MM/yyyy HH:mm")

                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>

                            <td colspan="4"
                                class="text-center text-muted">

                                No survey results found.

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>