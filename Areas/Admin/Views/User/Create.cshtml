@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Create User";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <!-- PAGE HEADER -->

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-person-plus"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        User Management
                    </p>

                    <h1 class="h3 mb-1">
                        Create New User
                    </h1>

                    <p class="text-muted mb-0">
                        Add a new account into the Mental Health Management System.
                    </p>

                </div>

            </div>

            <div class="heading-actions">

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">

                    <i class="bi bi-arrow-left"></i>
                    Back to Users

                </a>

            </div>

        </div>

        <!-- FORM -->

        <section class="row g-3">

            <div class="col-xl-8">

                <form method="post" class="panel">

                    <div class="panel-header">

                        <div>

                            <h2 class="h5 mb-1 section-title">

                                <i class="bi bi-person-fill-add"></i>

                                <span>
                                    User Information
                                </span>

                            </h2>

                            <p class="text-muted mb-0">
                                Enter account information below.
                            </p>

                        </div>

                    </div>

                    <div class="row g-3">

                        <div class="col-md-6">

                            <label class="form-label">
                                Full Name
                            </label>

                            <input type="text"
                                   class="form-control"
                                   placeholder="Nguyễn Văn A">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Username
                            </label>

                            <input type="text"
                                   class="form-control"
                                   placeholder="username">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Email
                            </label>

                            <input type="email"
                                   class="form-control"
                                   placeholder="user@uef.edu.vn">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Phone Number
                            </label>

                            <input type="text"
                                   class="form-control"
                                   placeholder="0901234567">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Password
                            </label>

                            <input type="password"
                                   class="form-control">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Confirm Password
                            </label>

                            <input type="password"
                                   class="form-control">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Role
                            </label>

                            <select class="form-select">

                                <option>
                                    Administrator
                                </option>

                                <option>
                                    Psychologist
                                </option>

                                <option>
                                    Student
                                </option>

                            </select>

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">
                                Status
                            </label>

                            <select class="form-select">

                                <option>
                                    Active
                                </option>

                                <option>
                                    Inactive
                                </option>

                            </select>

                        </div>

                        <div class="col-12">

                            <label class="form-label">
                                Notes
                            </label>

                            <textarea class="form-control"
                                      rows="4"
                                      placeholder="Additional information..."></textarea>

                        </div>

                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">

                        <a asp-action="Index"
                           class="btn btn-outline-secondary">

                            Cancel

                        </a>

                        <button type="submit"
                                class="btn btn-primary">

                            <i class="bi bi-check-circle"></i>
                            Create User

                        </button>

                    </div>

                </form>

            </div>

            <!-- SIDE INFO -->

            <div class="col-xl-4">

                <div class="panel h-100">

                    <h2 class="h5 mb-3 section-title">

                        <i class="bi bi-info-circle"></i>

                        <span>
                            User Roles
                        </span>

                    </h2>

                    <div class="mb-3">

                        <strong>Administrator</strong>

                        <p class="text-muted mb-0">
                            Full access to manage the system.
                        </p>

                    </div>

                    <div class="mb-3">

                        <strong>Psychologist</strong>

                        <p class="text-muted mb-0">
                            Manage student profiles, appointments and assessments.
                        </p>

                    </div>

                    <div>

                        <strong>Student</strong>

                        <p class="text-muted mb-0">
                            Participate in surveys and view personal results.
                        </p>

                    </div>

                </div>

            </div>

        </section>

    </div>

</main>