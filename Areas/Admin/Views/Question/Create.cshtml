@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Create Question";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <!-- PAGE HEADER -->

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-plus-circle"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        Survey Management
                    </p>

                    <h1 class="h3 mb-1">
                        Create Question
                    </h1>

                    <p class="text-muted mb-0">
                        Add a new question to the DASS-21 survey.
                    </p>

                </div>

            </div>

            <div class="heading-actions">

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">

                    <i class="bi bi-arrow-left"></i>
                    Back

                </a>

            </div>

        </div>

        <section class="row g-3">

            <!-- FORM -->

            <div class="col-12 col-xl-8">

                <form class="panel">

                    <div class="panel-header">

                        <div>

                            <h2 class="h5 mb-1 section-title">

                                <i class="bi bi-ui-checks-grid"></i>

                                <span>
                                    Question Information
                                </span>

                            </h2>

                            <p class="text-muted mb-0">

                                Enter question details.

                            </p>

                        </div>

                    </div>

                    <div class="row g-3">

                        <div class="col-md-6">

                            <label class="form-label">

                                Question Code

                            </label>

                            <input type="text"
                                   class="form-control"
                                   placeholder="Q22">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">

                                Display Order

                            </label>

                            <input type="number"
                                   class="form-control"
                                   value="22">

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">

                                Category

                            </label>

                            <select class="form-select">

                                <option>
                                    Select Category
                                </option>

                                <option>
                                    Stress
                                </option>

                                <option>
                                    Anxiety
                                </option>

                                <option>
                                    Depression
                                </option>

                            </select>

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">

                                Status

                            </label>

                            <select class="form-select">

                                <option selected>
                                    Active
                                </option>

                                <option>
                                    Inactive
                                </option>

                            </select>

                        </div>

                        <div class="col-12">

                            <label class="form-label">

                                Question Content

                            </label>

                            <textarea class="form-control"
                                      rows="6"
                                      placeholder="Enter question content..."></textarea>

                        </div>

                    </div>

                    <div class="d-flex justify-content-end mt-4">

                        <button type="submit"
                                class="btn btn-primary">

                            <i class="bi bi-check-circle"></i>

                            Create Question

                        </button>

                    </div>

                </form>

            </div>

            <!-- INFORMATION PANEL -->

            <div class="col-12 col-xl-4">

                <div class="panel">

                    <h2 class="h5 mb-3 section-title">

                        <i class="bi bi-info-circle"></i>

                        <span>
                            Guidelines
                        </span>

                    </h2>

                    <ul class="mb-0">

                        <li>
                            Question code should be unique.
                        </li>

                        <li>
                            Select the correct DASS domain.
                        </li>

                        <li>
                            Question order determines display sequence.
                        </li>

                        <li>
                            Active questions appear in surveys.
                        </li>

                    </ul>

                </div>

                <div class="panel mt-3">

                    <h2 class="h5 mb-3 section-title">

                        <i class="bi bi-clipboard-data"></i>

                        <span>
                            Current Statistics
                        </span>

                    </h2>

                    <div class="info-list">

                        <div>

                            <span>Total Questions</span>

                            <strong>21</strong>

                        </div>

                        <div>

                            <span>Stress</span>

                            <strong>7</strong>

                        </div>

                        <div>

                            <span>Anxiety</span>

                            <strong>7</strong>

                        </div>

                        <div>

                            <span>Depression</span>

                            <strong>7</strong>

                        </div>

                    </div>

                </div>

            </div>

        </section>

    </div>

</main>