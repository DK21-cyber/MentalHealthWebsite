@model PW.Models.Blog

@{
    ViewData["Title"] = "Blog Details";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <!-- Heading -->
        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-file-earmark-richtext"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        Content Management
                    </p>

                    <h1 class="h3 mb-1">
                        Blog Details
                    </h1>

                    <p class="text-muted mb-0">
                        View detailed information about this article.
                    </p>

                </div>

            </div>

            <div class="heading-actions">

                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-warning btn-sm">

                    <i class="bi bi-pencil"></i>

                    Edit

                </a>

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">

                    <i class="bi bi-arrow-left"></i>

                    Back

                </a>

            </div>

        </div>

        <div class="panel">

            <div class="panel-header">

                <h2 class="section-title">

                    <i class="bi bi-info-circle"></i>

                    Blog Information

                </h2>

            </div>

            <div class="row">

                <div class="col-lg-4 text-center">

                    @if (!string.IsNullOrEmpty(Model.Thumbnail))
                    {
                        <img src="@Model.Thumbnail"
                             class="img-fluid rounded shadow"
                             style="max-height:300px;" />
                    }
                    else
                    {
                        <img src="/images/no-image.png"
                             class="img-fluid rounded shadow"
                             style="max-height:300px;" />
                    }

                </div>

                <div class="col-lg-8">

                    <table class="table table-bordered">

                        <tr>
                            <th width="180">Title</th>
                            <td>@Model.Title</td>
                        </tr>

                        <tr>
                            <th>Category</th>
                            <td>@Model.Category?.Name</td>
                        </tr>

                        <tr>
                            <th>Author</th>
                            <td>@Model.Author?.FullName</td>
                        </tr>

                        <tr>
                            <th>Summary</th>
                            <td>@Model.Summary</td>
                        </tr>

                        <tr>
                            <th>Views</th>
                            <td>@Model.ViewCount</td>
                        </tr>

                        <tr>
                            <th>Status</th>

                            <td>

                                @if (Model.IsPublished)
                                {
                                    <span class="badge bg-success">
                                        Published
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">
                                        Draft
                                    </span>
                                }

                            </td>

                        </tr>

                        <tr>
                            <th>Created</th>
                            <td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>

                        <tr>
                            <th>Updated</th>
                            <td>@Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>

                    </table>

                </div>

            </div>

            <hr />

            <h5>

                <i class="bi bi-file-text"></i>

                Content

            </h5>

            <div class="border rounded p-4 bg-light">

                @Html.Raw(Model.Content)

            </div>

        </div>

    </div>

</main>