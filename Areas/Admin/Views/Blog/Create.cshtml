@model PW.Models.Blog

@{
    ViewData["Title"] = "Create Blog";
}

<main class="dashboard-content">

    <div class="container-fluid px-3 px-lg-4 py-4">

        <!-- Heading -->

        <div class="page-heading">

            <div class="page-heading-copy">

                <span class="page-icon">
                    <i class="bi bi-journal-plus"></i>
                </span>

                <div>

                    <p class="eyebrow mb-1">
                        Content Management
                    </p>

                    <h1 class="h3 mb-1">
                        Create Blog
                    </h1>

                    <p class="text-muted mb-0">
                        Publish a new mental health article.
                    </p>

                </div>

            </div>

            <div class="heading-actions">

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm">

                    <i class="bi bi-arrow-left"></i>

                    Back

                </a>

            </div>

        </div>

        <form asp-action="Create"
              method="post"
              class="panel">

            <div class="panel-header">

                <div>

                    <h2 class="section-title">

                        <i class="bi bi-pencil-square"></i>

                        Blog Information

                    </h2>

                </div>

            </div>

            <div class="row g-3">

                <div class="col-md-8">

                    <label asp-for="Title" class="form-label"></label>

                    <input asp-for="Title"
                           class="form-control" />

                    <span asp-validation-for="Title"
                          class="text-danger"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="CategoryId"
                           class="form-label"></label>

                    <select asp-for="CategoryId"
                            asp-items="ViewBag.CategoryId"
                            class="form-select">
                    </select>

                </div>

                <div class="col-12">

                    <label asp-for="Summary"
                           class="form-label"></label>

                    <textarea asp-for="Summary"
                              rows="3"
                              class="form-control">

                    </textarea>

                </div>

                <div class="col-12">

                    <label asp-for="Thumbnail"
                           class="form-label"></label>

                    <input asp-for="Thumbnail"
                           class="form-control" />

                </div>

                <div class="col-12">

                    <label asp-for="Content"
                           class="form-label"></label>

                    <textarea asp-for="Content"
                              rows="12"
                              class="form-control"
                              id="editor">

                    </textarea>

                </div>

                <div class="col-md-4">

                    <div class="form-check mt-4">

                        <input asp-for="IsPublished"
                               class="form-check-input" />

                        <label asp-for="IsPublished"
                               class="form-check-label">

                            Publish immediately

                        </label>

                    </div>

                </div>

            </div>

            <div class="mt-4 text-end">

                <button class="btn btn-primary">

                    <i class="bi bi-check-circle"></i>

                    Create Blog

                </button>

            </div>

        </form>

    </div>

</main>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}